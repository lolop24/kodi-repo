<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="service.lolop-logsender"
       name="Lolop Log Sender"
       version="0.1.0"
       provider-name="Codex">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>

  <extension point="xbmc.python.script" library="default.py">
    <provides>executable</provides>
  </extension>

  <extension point="xbmc.service" library="service.py" />

  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Send Kodi logs to the TitDeepL helper</summary>
    <description lang="en_GB">Small diagnostic addon for Android and Xbox Kodi. It sends kodi.log and kodi.old.log to the configured TitDeepL helper so update failures can be inspected remotely.</description>
    <platform>all</platform>
    <license>MIT</license>
  </extension>
</addon>

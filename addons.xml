<?xml version="1.0" encoding="UTF-8"?>
<addons>
    <addon id="plugin.video.csfd-rebricek" name="ČSFD Rebríček" version="12.2.0" provider-name="CSFD-SC-Bridge">
        <requires>
            <import addon="xbmc.python" version="3.0.0" />
            <import addon="xbmc.addon" version="21.0.0" />
            <import addon="script.module.beautifulsoup4" version="4.9.3" />
            <import addon="script.module.requests" version="2.25.0" />
        </requires>
        <extension point="xbmc.python.pluginsource" library="default.py">
            <provides>video</provides>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="en_gb">ČSFD Rankings with Stream Cinema integration</summary>
            <summary lang="sk">ČSFD Rebríčky so Stream Cinema integráciou</summary>
            <summary lang="cs">ČSFD Žebříčky se Stream Cinema integrací</summary>
            <description lang="en_gb">Best movies and TV series from ČSFD rankings with direct Stream Cinema integration. Green dot = available on SC.</description>
            <description lang="sk">Najlepšie filmy a seriály z ČSFD rebríčkov s priamym prepojením na Stream Cinema. Zelená bodka = dostupné na SC.</description>
            <description lang="cs">Nejlepší filmy a seriály z ČSFD žebříčků s přímým propojením na Stream Cinema. Zelená tečka = dostupné na SC.</description>
            <platform>all</platform>
        </extension>
    </addon>
    <addon id="repository.42polol" name="42po.lol Repository" version="1.0.0" provider-name="lolop24">
        <requires>
            <import addon="xbmc.addon" version="12.0.0" />
        </requires>
        <extension point="xbmc.addon.repository" name="42po.lol Repository">
            <dir>
                <info compressed="false">http://42po.lol/addons.xml</info>
                <checksum>http://42po.lol/addons.xml.md5</checksum>
                <datadir zip="true">http://42po.lol/</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="sk">CS Kodi repozitár</summary>
            <summary lang="cs">CS Kodi repozitář</summary>
            <summary lang="en">CS Kodi repository</summary>
            <description lang="sk">CS kodi repo - ČSFD Rebríček a Titulky DualSub</description>
            <description lang="en">CS kodi repo - ČSFD Rankings and Titulky DualSub</description>
            <platform>all</platform>
            <license>GPL-2.0-only</license>
        </extension>
    </addon>
    <addon id="service.subtitles.titulky-dualsub" name="Titulky DualSub" version="2.0.0" provider-name="community">
        <requires>
            <import addon="xbmc.python" version="3.0.0" />
        </requires>
        <extension point="xbmc.subtitle.module" library="service.py" />
        <extension point="xbmc.addon.metadata">
            <platform>all</platform>
        </extension>
    </addon>
</addons>

<?xml version="1.0" encoding="UTF-8"?>
<addons>
    <addon id="plugin.video.csfd-rebricek" name="ČSFD Rebríček" version="12.3.0" provider-name="CSFD-SC-Bridge">
        <requires>
            <import addon="xbmc.python" version="3.0.0" />
            <import addon="xbmc.addon" version="21.0.0" />
            <import addon="script.module.beautifulsoup4" version="4.9.3" />
            <import addon="script.module.requests" version="2.25.0" />
        </requires>
        <extension point="xbmc.python.pluginsource" library="default.py">
            <provides>video</provides>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="en_gb">ČSFD Rankings with Stream Cinema integration</summary>
            <summary lang="sk">ČSFD Rebríčky so Stream Cinema integráciou</summary>
            <summary lang="cs">ČSFD Žebříčky se Stream Cinema integrací</summary>
            <description lang="en_gb">Best movies and TV series from ČSFD rankings with direct Stream Cinema integration. Green dot = available on SC.</description>
            <description lang="sk">Najlepšie filmy a seriály z ČSFD rebríčkov s priamym prepojením na Stream Cinema. Zelená bodka = dostupné na SC.</description>
            <description lang="cs">Nejlepší filmy a seriály z ČSFD žebříčků s přímým propojením na Stream Cinema. Zelená tečka = dostupné na SC.</description>
            <platform>all</platform>
        </extension>
    </addon>
    <addon id="repository.42polol" name="42po.lol Repository" version="1.0.0" provider-name="lolop24">
        <requires>
            <import addon="xbmc.addon" version="12.0.0" />
        </requires>
        <extension point="xbmc.addon.repository" name="42po.lol Repository">
            <dir>
                <info compressed="false">http://42po.lol/addons.xml</info>
                <checksum algo="md5">http://42po.lol/addons.xml.md5</checksum>
                <datadir zip="true">http://42po.lol/</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="sk">CS Kodi repozitár</summary>
            <summary lang="cs">CS Kodi repozitář</summary>
            <summary lang="en">CS Kodi repository</summary>
            <description lang="sk">CS kodi repo - ČSFD Rebríček a Titulky DualSub</description>
            <description lang="en">CS kodi repo - ČSFD Rankings and Titulky DualSub</description>
            <platform>all</platform>
            <license>GPL-2.0-only</license>
        </extension>
    </addon>
    <addon id="service.subtitles.titulky-dualsub" name="Titulky DualSub (OpenSubtitles + Titulky.com)" version="1.3.0" provider-name="community">
        <requires>
            <import addon="xbmc.python" version="3.0.0" />
            <import addon="script.module.requests" version="2.9.1" />
            <import addon="script.module.chardet" version="2.3.0" />
            <import addon="script.module.pysubs2" version="1.3.1" optional="true" />
        </requires>
        <extension point="xbmc.subtitle.module" library="service.py">
            <provides>
                <subtitle>
                    <language>af</language>
                    <language>sq</language>
                    <language>ar</language>
                    <language>hy</language>
                    <language>bs</language>
                    <language>bg</language>
                    <language>ca</language>
                    <language>zh</language>
                    <language>hr</language>
                    <language>cs</language>
                    <language>da</language>
                    <language>nl</language>
                    <language>en</language>
                    <language>eo</language>
                    <language>et</language>
                    <language>fi</language>
                    <language>fr</language>
                    <language>de</language>
                    <language>el</language>
                    <language>he</language>
                    <language>hi</language>
                    <language>hu</language>
                    <language>id</language>
                    <language>it</language>
                    <language>ja</language>
                    <language>ko</language>
                    <language>lv</language>
                    <language>lt</language>
                    <language>mk</language>
                    <language>ms</language>
                    <language>no</language>
                    <language>fa</language>
                    <language>pl</language>
                    <language>pt</language>
                    <language>ro</language>
                    <language>ru</language>
                    <language>sr</language>
                    <language>sk</language>
                    <language>sl</language>
                    <language>es</language>
                    <language>sv</language>
                    <language>ta</language>
                    <language>th</language>
                    <language>tr</language>
                    <language>uk</language>
                    <language>vi</language>
                </subtitle>
            </provides>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="en">Search and download dual subtitles from OpenSubtitles.com, Titulky.com, and TVsubtitles.net simultaneously</summary>
            <summary lang="sk">Vyhľadávanie a sťahovanie duálnych titulkov z OpenSubtitles.com, Titulky.com a TVsubtitles.net súčasne</summary>
            <summary lang="cs">Hledání a stahování duálních titulků z OpenSubtitles.com, Titulky.com a TVsubtitles.net současně</summary>
            <description lang="en">
                Combines OpenSubtitles.com, Titulky.com and TVsubtitles.net into a single dual-subtitle addon.
                Searches all sources in parallel. Select two subtitles — first selected appears at the TOP (white),
                second at the BOTTOM (yellow). Supports Ukrainian, English, and 40+ languages.
                TVsubtitles.net is searched automatically for TV shows (Ukrainian, English and others — not Czech/Slovak).
                Requires OpenSubtitles.com and/or Titulky.com credentials in addon settings.
            </description>
            <description lang="sk">
                Kombinuje zdroje titulkov OpenSubtitles.com, Titulky.com a TVsubtitles.net do jedného duálneho addonu.
                Vyhľadáva všetky zdroje paralelne. Vyber dva titulky — prvý vybraný ide HORE (biele),
                druhý vybraný ide DOLE (žlté). TVsubtitles.net sa prehľadáva automaticky pre seriály
                (ukrajinčina, angličtina a ďalšie — nie čeština/slovenčina).
            </description>
            <platform>all</platform>
            <license>GPL-2.0-only</license>
            <source>https://github.com/</source>
        </extension>
    </addon>
    <addon id="skin.lolop" version="1.0.0" name="Lolop Skin" provider-name="lolop24">

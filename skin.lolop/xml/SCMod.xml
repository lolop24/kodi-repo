	<include name="SCInfoWidget">
		<definition>
			<control type="group" id="99999">
				<visible>!Container($PARAM[list_id]).IsUpdating + Control.HasFocus($PARAM[list_id]) + !Control.HasFocus(9000) + !ControlGroup(700).HasFocus + !ControlGroup(710).HasFocus + !String.IsEmpty(Container($PARAM[list_id]).ListItem.dbtype)</visible>
				<include>OpenClose_Left</include>
				<include>Visible_Left</include>
				<include content="ContentPanel">
					<param name="width" value="522" />
				</include>
				<control type="grouplist">
					<left>20</left>
					<top>110</top>
					<bottom>40</bottom>
					<control type="textbox">
						<width>422</width>
						<height>94</height>
						<aligny>center</aligny>
						<font>font32_title</font>
						<label>$INFO[Container($PARAM[list_id]).ListItem.Label]</label>
						<shadowcolor>text_shadow</shadowcolor>
					</control>
					<control type="fadelabel">
						<height>50</height>
						<width>422</width>
						<aligny>center</aligny>
						<label>$INFO[Container($PARAM[list_id]).ListItem.Genre]</label>
						<textcolor>button_focus</textcolor>
						<shadowcolor>text_shadow</shadowcolor>
						<visible>!String.IsEmpty(Container($PARAM[list_id]).ListItem.Genre)</visible>
					</control>
					<control type="image">
						<height>270</height>
						<width>422</width>
						<aspectratio aligny="center" align="left">keep</aspectratio>
						<texture background="true"></texture>
						<texture fallback="special://skin/extras/backgrounds/pattern2.jpg" background="true">$INFO[Container($PARAM[list_id]).ListItem.Art(thumb)]</texture>
						<visible>!String.IsEmpty(Container($PARAM[list_id]).ListItem.Art(thumb))</visible>
					</control>
					<control type="image">
						<height>270</height>
						<width>422</width>
						<aspectratio aligny="center" align="left">keep</aspectratio>
						<texture background="true"></texture>
						<texture fallback="special://skin/extras/backgrounds/pattern7.jpg" background="true">$INFO[Container($PARAM[list_id]).ListItem.Art(fanart)]</texture>
						<visible>String.IsEmpty(Container($PARAM[list_id]).ListItem.Art(thumb))</visible>
					</control>
					<control type="textbox">
						<height>490</height>
						<width>422</width>
						<label>$INFO[Container($PARAM[list_id]).ListItem.Tagline,[I],[/I][CR][CR]]$INFO[Container($PARAM[list_id]).ListItem.Plot][CR]</label>
						<font>font16</font>
						<shadowcolor>text_shadow</shadowcolor>
						<autoscroll delay="3000" time="1000" repeat="10000">Skin.HasSetting(autoscroll)</autoscroll>
						<visible>!Container($PARAM[list_id]).ListItem.IsCollection</visible>
					</control>
				</control>
			</control>
		</definition>
	</include>
